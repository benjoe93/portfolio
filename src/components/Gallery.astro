---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

type GalleryItem = {
  src: ImageMetadata | string;
  alt?: string;
  caption?: string;
};

interface Props {
  items: GalleryItem[];
  heading?: string;
}
const { items, heading = 'Gallery' } = Astro.props;
---
{items.length > 0 && (
  <section class="gallery" aria-label={heading}>
    <h2 class="gallery-heading">{heading}</h2>
    <div class="gallery-grid">
      {items.map((item) => (
        <figure class="gallery-item">
          {typeof item.src === 'string' ? (
            <img src={item.src} alt={item.alt ?? ''} loading="lazy" decoding="async" />
          ) : (
            <Image
              src={item.src}
              alt={item.alt ?? ''}
              widths={[400, 800, 1200]}
              sizes="(max-width: 40rem) 100vw, (max-width: 64rem) 50vw, 33vw"
              loading="lazy"
            />
          )}
          {item.caption && <figcaption class="muted">{item.caption}</figcaption>}
        </figure>
      ))}
    </div>
  </section>
)}

<style>
  .gallery { margin-top: var(--space-12); }
  .gallery-heading { margin-bottom: var(--space-6); }
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 18rem), 1fr));
    gap: var(--space-4);
  }
  .gallery-item { margin: 0; display: flex; flex-direction: column; gap: var(--space-2); }
  .gallery-item :global(img) {
    width: 100%;
    height: auto;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background: var(--surface);
  }
  .gallery-item figcaption { font-size: 0.85rem; }
</style>
