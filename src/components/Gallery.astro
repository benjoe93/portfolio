---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

type GalleryItem = {
  src: ImageMetadata | string;
  alt?: string;
  caption?: string;
};

interface Props {
  items: GalleryItem[];
  heading?: string;
}
const { items, heading = 'Gallery' } = Astro.props;

// Unique id so multiple galleries on one page stay independent.
const uid = 'gallery-' + Math.random().toString(36).slice(2, 9);

// Full-size source for the lightbox: remote strings pass through as-is; local
// assets expose their full-resolution optimized URL (larger than the thumbnail).
const lightboxItems = items.map((item) => ({
  full: typeof item.src === 'string' ? item.src : item.src.src,
  alt: item.alt ?? '',
  caption: item.caption ?? '',
}));
---
{items.length > 0 && (
  <section class="gallery" id={uid} aria-label={heading} data-gallery>
    <h2 class="gallery-heading">{heading}</h2>
    <div class="gallery-grid">
      {items.map((item, i) => (
        <figure class="gallery-item">
          <button class="gallery-trigger" type="button" data-index={i} aria-label={`Enlarge image ${i + 1}${item.alt ? `: ${item.alt}` : ''}`}>
            {typeof item.src === 'string' ? (
              <img src={item.src} alt={item.alt ?? ''} loading="lazy" decoding="async" />
            ) : (
              <Image
                src={item.src}
                alt={item.alt ?? ''}
                widths={[400, 800, 1200]}
                sizes="(max-width: 40rem) 100vw, (max-width: 64rem) 50vw, 33vw"
                loading="lazy"
              />
            )}
          </button>
          {item.caption && <figcaption class="muted">{item.caption}</figcaption>}
        </figure>
      ))}
    </div>

    <script type="application/json" data-gallery-items set:html={JSON.stringify(lightboxItems)} />

    <dialog class="lightbox" aria-label={`${heading} viewer`}>
      <div class="lightbox-inner">
        <button class="lb-btn lb-close" type="button" data-close aria-label="Close viewer">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18"/></svg>
        </button>
        <button class="lb-btn lb-prev" type="button" data-prev aria-label="Previous image">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 6l-6 6 6 6"/></svg>
        </button>
        <figure class="lightbox-figure">
          <img class="lightbox-img" src="" alt="" />
          <figcaption class="lightbox-caption">
            <span data-caption></span>
            <span class="lightbox-counter muted" data-counter></span>
          </figcaption>
        </figure>
        <button class="lb-btn lb-next" type="button" data-next aria-label="Next image">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 6l6 6-6 6"/></svg>
        </button>
      </div>
    </dialog>
  </section>
)}

<style>
  .gallery { margin-top: var(--space-12); }
  .gallery-heading { margin-bottom: var(--space-6); }
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 18rem), 1fr));
    gap: var(--space-4);
  }
  .gallery-item { margin: 0; display: flex; flex-direction: column; gap: var(--space-2); }
  .gallery-item figcaption { font-size: 0.85rem; }

  .gallery-trigger {
    display: block;
    padding: 0;
    border: 0;
    background: none;
    cursor: zoom-in;
    border-radius: var(--radius);
    width: 100%;
  }
  .gallery-trigger :global(img) {
    width: 100%;
    height: auto;
    border-radius: var(--radius);
    background: var(--surface);
    transition: transform 0.16s ease, box-shadow 0.16s ease;
  }
  .gallery-trigger:hover :global(img) { transform: translateY(-2px); box-shadow: 0 0 0 2px var(--accent); }

  /* ---- Lightbox ---- */
  .lightbox {
    padding: 0;
    border: 0;
    background: transparent;
    max-width: 100vw;
    max-height: 100vh;
    width: 100%;
    height: 100%;
    color: var(--text);
  }
  .lightbox::backdrop { background: rgba(0, 0, 0, 0.82); backdrop-filter: blur(2px); }
  .lightbox-inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: var(--space-3);
    width: 100%;
    height: 100%;
    padding: clamp(var(--space-3), 3vw, var(--space-8));
    box-sizing: border-box;
  }
  .lightbox-figure {
    margin: 0;
    grid-column: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    min-width: 0;
  }
  .lightbox-img {
    max-width: 100%;
    max-height: 82vh;
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: var(--radius);
    background: var(--surface);
  }
  .lightbox-caption {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-4);
    align-items: baseline;
    justify-content: center;
    text-align: center;
    color: #f2ede3;
    font-size: 0.95rem;
  }
  .lightbox-counter { color: rgba(242, 237, 227, 0.7); }

  .lb-btn {
    display: inline-grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.25);
    background: rgba(20, 19, 15, 0.6);
    color: #fff;
    cursor: pointer;
    transition: border-color 0.12s ease, background 0.12s ease, transform 0.12s ease;
  }
  .lb-btn:hover { border-color: var(--accent); background: rgba(20, 19, 15, 0.85); transform: scale(1.05); }
  .lb-prev { grid-column: 1; }
  .lb-next { grid-column: 3; }
  .lb-close {
    position: absolute;
    top: var(--space-4);
    right: var(--space-4);
    z-index: 2;
  }
  .lightbox[data-single] .lb-prev,
  .lightbox[data-single] .lb-next { display: none; }

  @media (max-width: 34rem) {
    .lb-prev, .lb-next { width: 40px; height: 40px; }
    .lightbox-img { max-height: 72vh; }
  }
</style>

<script>
  type LbItem = { full: string; alt: string; caption: string };

  function initGallery(section: HTMLElement) {
    const dataEl = section.querySelector<HTMLScriptElement>('[data-gallery-items]');
    const dialog = section.querySelector<HTMLDialogElement>('.lightbox');
    if (!dataEl || !dialog) return;

    let items: LbItem[] = [];
    try {
      items = JSON.parse(dataEl.textContent || '[]');
    } catch {
      return;
    }
    if (items.length === 0) return;

    const img = dialog.querySelector<HTMLImageElement>('.lightbox-img')!;
    const captionEl = dialog.querySelector<HTMLElement>('[data-caption]')!;
    const counterEl = dialog.querySelector<HTMLElement>('[data-counter]')!;
    const triggers = Array.from(section.querySelectorAll<HTMLButtonElement>('.gallery-trigger'));

    dialog.toggleAttribute('data-single', items.length < 2);

    let index = 0;
    let lastTrigger: HTMLElement | null = null;

    const render = () => {
      const it = items[index];
      img.src = it.full;
      img.alt = it.alt;
      captionEl.textContent = it.caption;
      counterEl.textContent = items.length > 1 ? `${index + 1} / ${items.length}` : '';
    };
    const go = (delta: number) => {
      index = (index + delta + items.length) % items.length;
      render();
    };
    const open = (i: number, trigger: HTMLElement) => {
      index = i;
      lastTrigger = trigger;
      render();
      dialog.showModal();
    };

    triggers.forEach((btn, i) => {
      btn.addEventListener('click', () => open(i, btn));
    });
    section.querySelector('[data-prev]')?.addEventListener('click', () => go(-1));
    section.querySelector('[data-next]')?.addEventListener('click', () => go(1));
    section.querySelector('[data-close]')?.addEventListener('click', () => dialog.close());

    dialog.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowRight') { e.preventDefault(); go(1); }
      else if (e.key === 'ArrowLeft') { e.preventDefault(); go(-1); }
    });

    // Backdrop click (clicks that land on the dialog element itself, outside content).
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) dialog.close();
    });

    // Return focus to the originating thumbnail on close.
    dialog.addEventListener('close', () => {
      lastTrigger?.focus();
      lastTrigger = null;
    });

    // Touch swipe.
    let startX = 0;
    dialog.addEventListener('touchstart', (e) => { startX = e.changedTouches[0].clientX; }, { passive: true });
    dialog.addEventListener('touchend', (e) => {
      const dx = e.changedTouches[0].clientX - startX;
      if (Math.abs(dx) > 40) go(dx < 0 ? 1 : -1);
    }, { passive: true });
  }

  document.querySelectorAll<HTMLElement>('[data-gallery]').forEach(initGallery);
</script>
