---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import { getCollection, render } from "astro:content";
import Gallery from "../../components/Gallery.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const work = await getCollection("work", ({ data }) => !data.draft);
  return work.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;
const isRemote = typeof d.cover === "string";

const links = [
  d.repoUrl && { href: d.repoUrl, label: "View code" },
  d.artstationUrl && { href: d.artstationUrl, label: "View on ArtStation" },
].filter(Boolean) as { href: string; label: string }[];

const fmt = (date: Date) => date.toLocaleDateString("en-US", { year: "numeric", month: "long" });
---

<BaseLayout title={d.title} description={d.summary} image={isRemote ? (d.cover as string) : undefined}>
  <article class="container section">
    <header class="prose work-header">
      <div class="stack">
        <p class="eyebrow">Work</p>
        <h1>{d.title}</h1>
        <!-- <p class="lede muted">{d.summary}</p> -->
        <p class="muted"><time datetime={d.date.toISOString()}>{fmt(d.date)}</time></p>
        <ul class="taglist">
          {d.disciplines.map((t) => <li class="tag">{t}</li>)}
        </ul>
      </div>
    </header>

    {
      !d.hideCover && (
        <figure class="cover">
          {isRemote ? (
            <img src={d.cover as string} alt={d.coverAlt} width="1200" height="800" />
          ) : (
            <Image
              src={d.cover as ImageMetadata}
              alt={d.coverAlt}
              widths={[600, 1200]}
              sizes="(max-width: 48rem) 100vw, 48rem"
            />
          )}
        </figure>
      )
    }

    <div class="prose work-body">
      <Content />
    </div>

    {
      d.gallery && d.gallery.length > 0 && (
        <div class="work-gallery">
          <Gallery items={d.gallery} />
        </div>
      )
    }
    <footer>
      {
        links.length > 0 && (
          <div class="work-links">
            {links.map((l, i) => (
              <a class={i === 0 ? "btn btn--primary" : "btn"} href={l.href} target="_blank" rel="noopener">
                {l.label} ↗
              </a>
            ))}
          </div>
        )
      }
    </footer>
  </article>
</BaseLayout>

<style>
  .work-header {
    margin-inline: auto;
    margin-bottom: var(--space-8);
  }
  .taglist {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .lede {
    font-size: 1.2rem;
  }
  .work-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-2);
  }
  .cover {
    margin: 0 auto var(--space-8);
    max-width: var(--maxw-prose);
  }
  .cover img {
    width: 100%;
    border-radius: var(--radius);
    border: 1px solid var(--border);
  }
  .work-body {
    margin-inline: auto;
  }
  .work-body :global(h2) {
    margin-top: var(--space-8);
  }
  .work-gallery {
    max-width: var(--maxw-prose);
    margin-inline: auto;
  }
</style>
