---
import { site } from "../data/site";
import BaseLayout from "../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// Edit these to make the page yours.
const skills = [
  "Tool & pipeline development (Python, C++)",
  "Procedural workflows",
  "Shader creation",
  "Optimization & profiling",
  "Python",
  "C++",
  "Unreal Engine",
  "Houdini",
  "Blender",
  "Maya",
  "Substance",
];

const experience = [
  {
    role: "Senior Technical Artist",
    org: "Studio Gobo",
    period: "2026 — Present",
    note: "Shaders, tools, and pipeline work for real-time projects.",
  },
  {
    role: "Technical Artist",
    org: "Studio Gobo",
    period: "2024 — 2026",
    note: "Shaders, tools, and pipeline work for real-time projects.",
  },
  {
    role: "Technical Artist",
    org: "Free Radical Design",
    period: "2023 — 2024",
    note: "Shaders, tools, and pipeline work for real-time projects.",
  },
  {
    role: "Technical Artist",
    org: "Do Digital Agency",
    period: "2021 — 2023",
    note: "Shaders, tools, and pipeline work for real-time projects.",
  },
  {
    role: "Junior Environment Artist (FTC)",
    org: "nDreams",
    period: "2020",
    note: "Material authoring and asset pipeline support.",
  },
];

// Shipped titles you worked on. Edit these — link a store/press page if you have one.
const releases = [
  {
    title: "Lego Horizon Adventures",
    year: "2024",
    platforms: "PC, PlayStation5, Nintendo Switch",
    role: "Technical Artist",
    url: "https://www.playstation.com/en-gb/games/lego-horizon-adventures/",
  },
  {
    title: "Fracked",
    year: "2021",
    platforms: "PS VR",
    role: "Junior Environment Artist",
    url: "https://ndreams.com/games/fracked",
  },
  {
    title: "Phantom: Covert Ops",
    year: "2020",
    platforms: "Oculus",
    role: "Junior Environment Artist",
    url: "https://ndreams.com/games/phantom-covert-ops",
  },
];
---

<BaseLayout title="About" description={`About ${site.name}, ${site.role}.`}>
  <section class="section container">
    <div class="about-grid">
      <div class="prose">
        <p class="eyebrow">About</p>
        <h1>{site.name}</h1>
        <!-- <p class="lede muted">{site.tagline}</p> -->
        <p>
          Senior Technical Artist with 6+ years across AAA and indie studios, specialising in production tools and
          pipelines for scalable content creation. Proven track record of shipping across PC, console and VR, with a
          strong focus on cross-discipline collaboration.
        </p>

        <h2>Skills</h2>
        <ul class="skills">
          {skills.map((s) => <li class="tag">{s}</li>)}
        </ul>

        <h2>Experience</h2>
        <ul class="timeline">
          {
            experience.map((e) => (
              <li>
                <div class="timeline-head">
                  <strong>{e.role}</strong> · {e.org}
                  <span class="muted timeline-period">{e.period}</span>
                </div>
                <p class="muted">{e.note}</p>
              </li>
            ))
          }
        </ul>

        <h2>Releases</h2>
        <ul class="timeline">
          {
            releases.map((r) => (
              <li>
                <div class="timeline-head">
                  <strong>
                    {r.url ? (
                      <a href={r.url} target="_blank" rel="noopener">
                        {r.title}
                      </a>
                    ) : (
                      r.title
                    )}
                  </strong>
                  <span class="muted"> · {r.platforms}</span>
                  <span class="muted timeline-period">{r.year}</span>
                </div>
                <p class="muted">{r.role}</p>
              </li>
            ))
          }
        </ul>
      </div>

      <aside class="about-side">
        <div class="card-panel stack">
          <h2 class="side-title">Get in touch</h2>
          <p class="muted">The fastest way to reach me.</p>
          <!-- <a class="btn btn--primary" href={`mailto:${site.email}`}>Email me</a> -->
          <!-- <a class="btn" href={`${base}/resume.pdf`} target="_blank" rel="noopener">Download Resume (PDF)</a> -->
          <ul class="side-links">
            <li><a href={site.email} target="_blank" rel="me noopener">Email me ↗</a></li>
            <li><a href={site.socials.artstation} target="_blank" rel="me noopener">ArtStation ↗</a></li>
            <li><a href={site.socials.github} target="_blank" rel="me noopener">GitHub ↗</a></li>
            <li><a href={site.socials.linkedin} target="_blank" rel="me noopener">LinkedIn ↗</a></li>
          </ul>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
  }
  @media (min-width: 52rem) {
    .about-grid {
      grid-template-columns: 1fr 20rem;
      align-items: start;
    }
    .about-side {
      position: sticky;
      top: 5rem;
    }
  }
  .skills,
  .side-links {
    list-style: none;
    padding: 0;
  }
  .skills {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin: 0;
  }
  .timeline {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--space-6);
  }
  .timeline-head {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    align-items: baseline;
  }
  .timeline-period {
    margin-inline-start: auto;
    font-size: 0.9rem;
  }
  .card-panel {
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: var(--space-6);
    box-shadow: var(--shadow);
  }
  .side-title {
    font-size: 1.25rem;
    margin: 0;
  }
  .side-links {
    display: grid;
    gap: var(--space-2);
    margin: var(--space-2) 0 0;
  }
  .side-links a {
    font-weight: 600;
    text-decoration: none;
  }
  .side-links a:hover {
    text-decoration: underline;
  }
</style>
